# ============================================
# FORGE — environment template
# Copy to `.env.local` for local dev. NEVER commit `.env.local`.
# ============================================
# SAFE in the Vite SPA (public / anon):
#   VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY, VITE_PAYSTACK_PUBLIC_KEY,
#   VITE_SENTRY_DSN, VITE_AI_PROVIDER, VITE_OLLAMA_* (local only)
#
# NEVER put these in VITE_* (they ship in the browser bundle):
#   FCM server key, Twilio / Africa's Talking tokens, Paystack secret,
#   OpenRouter / Gemini secrets (prefer Edge Function secrets), service role key
# ============================================

# AI Provider Configuration
# Set which AI provider to use: 'openrouter' (cloud, recommended), 'ollama' (local), or 'gemini' (cloud backup)
VITE_AI_PROVIDER=openrouter

# OpenRouter — PREFER Edge Function only (production)
#   supabase secrets set OPENROUTER_API_KEY=sk-or-v1-...
#   supabase functions deploy ai-chat
#   See: supabase/functions/ai-chat/README.md
#
# Optional SPA fallback (key is PUBLIC in the browser — avoid in production):
# VITE_OPENROUTER_API_KEY=sk-or-v1-your_key_here

# Ollama Configuration (Local AI fallback)
# Install Ollama: https://ollama.ai/download
# Run: ollama pull gemma3:4b && ollama serve
VITE_OLLAMA_URL=http://localhost:11434
VITE_OLLAMA_MODEL=gemma3:4b

# Gemini — prefer server-side; if set as VITE_ it is public in the bundle
# VITE_GEMINI_API_KEY=

# Supabase Configuration
# Get these values from Supabase Dashboard → Settings → API
# Forge is a Vite SPA — use VITE_* vars only (NOT Next.js NEXT_PUBLIC_* or @supabase/ssr)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
# Use the publishable key (sb_publishable_...) or legacy anon JWT (eyJ...) — both work with @supabase/supabase-js
VITE_SUPABASE_ANON_KEY=your_supabase_publishable_or_anon_key_here

# Sentry Configuration
# Get your DSN from your Sentry project settings: https://sentry.io
VITE_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Sentry Source Map Upload Configuration (for production builds — CI only, not VITE_)
# Get your auth token from: https://sentry.io/settings/auth-tokens/
SENTRY_AUTH_TOKEN=your_sentry_auth_token_here
SENTRY_ORG=your_sentry_org_slug
SENTRY_PROJECT=your_sentry_project_slug

# Paystack Configuration (PUBLIC key only in the SPA)
# Get your public key from: https://dashboard.paystack.com/#/settings/developers
VITE_PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key_here

# Paystack Secret Key — SERVER-SIDE ONLY (do NOT use VITE_ prefix)
# Used by the Supabase Edge Function for webhook HMAC-SHA512 verification.
# Set via: supabase secrets set PAYSTACK_SECRET_KEY=sk_test_...
# See: supabase/functions/paystack-webhook/README.md
# PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key_here

# Firebase Cloud Messaging — SERVER-SIDE ONLY (Edge Function secret)
# Do NOT set VITE_FCM_SERVER_KEY — it would expose the key in the client bundle.
#   supabase secrets set FCM_SERVER_KEY=your_firebase_server_key
#   supabase functions deploy send-push-notification
# Optional cron/service invoke: supabase secrets set PUSH_CRON_SECRET=...
# See: supabase/functions/send-push-notification/README.md

# SMS/OTP — SERVER-SIDE ONLY when re-enabled (OTP deferred for beta)
# Do NOT set VITE_TWILIO_* or VITE_AT_* — client SMS is gated off in production.
# Future: Edge Function secrets TWILIO_* / AT_* only.

# Google OAuth Configuration
# Configure in Supabase Dashboard: Authentication > Providers > Google
# 1. Enable Google provider in Supabase
# 2. Add your Google OAuth Client ID and Secret from Google Cloud Console
# 3. Set redirect URL in Google Console: https://your-project-id.supabase.co/auth/v1/callback
# No env vars needed here - configured in Supabase dashboard
